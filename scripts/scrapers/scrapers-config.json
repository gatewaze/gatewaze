{
  "scrapers": {
    "dev-events-conferences": {
      "name": "Dev.Events Conferences",
      "url": "https://dev.events/",
      "type": "conference",
      "scraper": "DevEventsConferenceScraper",
      "enabled": true,
      "config": {
        "baseUrl": "https://dev.events",
        "pageSelector": "#events .row.columns.is-mobile",
        "paginationEnabled": true,
        "maxPages": 100,
        "regions": ["NA", "EU", "AS", "SA", "AF", "OC", "ON"]
      }
    },
    "dev-events-meetups": {
      "name": "Dev.Events Meetups",
      "url": "https://dev.events/meetups",
      "type": "meetup",
      "scraper": "DevEventsMeetupScraper",
      "enabled": true,
      "config": {
        "baseUrl": "https://dev.events/meetups",
        "eventSelector": "[data-type='EducationEvent']",
        "useJsonLD": true,
        "regions": ["NA", "EU", "AS", "SA", "AF", "OC", "ON"]
      }
    },
    "luma-events": {
      "name": "Luma Events",
      "url": "https://lu.ma",
      "type": "mixed",
      "scraper": "LumaEventsScraper",
      "enabled": true,
      "config": {
        "calendars": [
          {
            "name": "GenAI Collective",
            "url": "https://lu.ma/genai-collective",
            "description": "AI and machine learning focused events"
          },
          {
            "name": "NYC MLOps",
            "url": "https://lu.ma/nyc.mlops",
            "description": "MLOps and data engineering events in NYC"
          }
        ],
        "scrollTimeout": 5000,
        "maxScrollAttempts": 50
      }
    }
  },
  "globalConfig": {
    "outputPath": "./scraped-events.json",
    "processedEventsPath": "./processed-events.csv",
    "topicsPath": "./topics.json",
    "countryCodesPath": "./country-codes.json",
    "regionCodesPath": "./region-codes.json",
    "headless": true,
    "urlValidation": {
      "enabled": true,
      "timeout": 10000,
      "retries": 2
    },
    "geocoding": {
      "enabled": true,
      "apiKey": null,
      "cacheEnabled": true,
      "cachePath": "./geocoding-cache.json"
    },
    "database": {
      "enabled": true,
      "supabaseUrl": "https://data.tech.tickets",
      "supabaseKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFqemxka29obG9reW1lcmxvYmZjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTgzMTE4NjAsImV4cCI6MjA3Mzg4Nzg2MH0.EnDLHAXdg-cxdlpMNC6Et5NjFCj-ls2gVkqxG4RpbxQ",
      "tableName": "events"
    },
    "deduplication": {
      "matchFields": ["eventLink", "eventTitle", "eventStart"],
      "fuzzyNameMatching": true,
      "similarityThreshold": 0.85
    }
  }
}