# ============================================================
# Gatewaze Configuration
# ============================================================
# Copy this file to .env and fill in the values.
#
# For Docker Compose: docker compose -f docker/docker-compose.yml up -d
# For development:    pnpm dev (after starting infrastructure)

# === Instance ===
INSTANCE_NAME=Gatewaze

# === Supabase ===
# For self-hosted: use the defaults below (they match Supabase's demo keys)
# For Supabase Cloud: replace with your project URL and keys
SUPABASE_URL=http://supabase.gatewaze.localhost
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
POSTGRES_PASSWORD=your-super-secret-password
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# === Auth ===
AUTH_PROVIDER=supabase

# === CI/CD ===
# Set to true to skip magic link emails during onboarding.
# The magic link is returned directly so the browser auto-authenticates.
# CI_MODE=true

# === Branding ===
# Set to true to hide Gatewaze logos and powered-by images (white-label)
DISABLE_BRANDING=false

# OIDC (only if AUTH_PROVIDER=oidc)
# OIDC_ISSUER_URL=https://keycloak.example.com/realms/gatewaze
# OIDC_CLIENT_ID=gatewaze-admin
# OIDC_CLIENT_SECRET=

# === Email ===
EMAIL_PROVIDER=sendgrid
# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Gatewaze

# SMTP (only if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=Gatewaze

# === File Storage ===
# Storage backend: "file" (local, default) or "s3" (S3-compatible)
STORAGE_BACKEND=file

# S3 configuration (only when STORAGE_BACKEND=s3)
# Works with AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces, etc.
# S3_BUCKET=my-gatewaze-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=false  # Set to true for MinIO and other S3-compatible stores

# === Redis ===
REDIS_PASSWORD=gatewaze

# === URLs ===
# Traefik .localhost domains (resolve to 127.0.0.1 automatically per RFC 6761)
ADMIN_URL=http://admin.gatewaze.localhost
PORTAL_URL=http://app.gatewaze.localhost
API_URL=http://api.gatewaze.localhost

# === Ports (direct access fallback) ===
# Services are also available via direct ports alongside Traefik routing
ADMIN_PORT=5274
PORTAL_PORT=3100
API_PORT=3002
KONG_PORT=54321
POSTGRES_PORT=54322
STUDIO_PORT=54323

# === Supabase Studio ===
STUDIO_DEFAULT_ORGANIZATION=Gatewaze
STUDIO_DEFAULT_PROJECT=Gatewaze

# ============================================================
# Optional Integrations (all features work without these)
# ============================================================

# === Stripe (Payments) ===
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# === Customer.io ===
# CUSTOMERIO_SITE_ID=
# CUSTOMERIO_API_KEY=
# CUSTOMERIO_APP_API_KEY=

# === YouTube ===
# YOUTUBE_API_KEY=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_CHANNEL_ID=
# YOUTUBE_REFRESH_TOKEN=

# === Slack ===
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_DEFAULT_BOT_TOKEN=
# SLACK_WORKSPACE_URL=

# === Analytics ===
# META_PIXEL_ID=
# META_ACCESS_TOKEN=
# REDDIT_PIXEL_ID=
# REDDIT_ACCESS_TOKEN=

# === AI / Search ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === URL Shortener ===
# SHORTIO_API_KEY=
# SHORTIO_DOMAIN=

# === CDN ===
# BUNNY_PULLZONE_URL=
# BUNNY_CDN_ENABLED=false
