# Worker Dev Dockerfile — mirrors docker/api/Dockerfile.dev so the
# worker process can run packages/api/src/workers/job-worker.ts via
# tsx with hot reload. The old layout (scripts/workers/job-worker.js)
# was a frozen prebuilt JS that did NOT call loadModuleQueues, so
# module-declared `workers: [...]` handlers were never registered.
# Moving to tsx-on-TS gives us the same `loadModuleQueues` path the
# api uses, which actually walks every loaded module and wires its
# handlers onto the shared `jobs` queue.

FROM node:20-slim

# Puppeteer / scraper deps stay — some worker handlers shell out to
# scrapling-fetcher which doesn't need Chromium, but scrapers/sites
# image-gen paths do. Keeping the install identical to the prior dev
# image keeps existing scraper jobs working through the cutover.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    chromium \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Pin to pnpm 10.x — `pnpm@latest` (currently 11.1.3) crashes on
# node 20 with ERR_UNKNOWN_BUILTIN_MODULE. The api/Dockerfile.dev has
# the same `@latest` line and works only because its image layer was
# built before that pnpm release; pinning here keeps fresh builds from
# tripping over the same regression.
RUN corepack enable && corepack prepare pnpm@10.31.0 --activate

WORKDIR /app

# Workspace root + tsconfig — same as api/Dockerfile.dev. We then carve
# out a packages-only workspace because the live module sources mounted
# under /gatewaze-modules etc. aren't available at build time.
COPY package.json ./
COPY tsconfig.json ./
RUN printf 'packages:\n  - "packages/*"\n' > pnpm-workspace.yaml

COPY packages/api/package.json packages/api/
COPY packages/shared/package.json packages/shared/

RUN --mount=type=cache,id=pnpm-worker-dev,target=/root/.local/share/pnpm/store \
    pnpm install --no-frozen-lockfile

# gatewaze.config.ts via the same CJS→ESM shim trick api uses.
COPY gatewaze.config.ts ./
RUN printf 'const m = require("./gatewaze.config.ts");\nconst c = m.default || m;\nObject.defineProperty(c, "__esModule", { value: true });\nmodule.exports = c;\nmodule.exports.default = c;\n' > gatewaze.config.js

# Shared package must be built so its `exports` map ./dist/* paths
# resolve. Same rationale as api/Dockerfile.dev.
COPY packages/shared/ packages/shared/
RUN pnpm --filter @gatewaze/shared build

# Copy api source (overridden by volume mount in compose.dev). The
# worker entry lives at packages/api/src/workers/job-worker.ts.
COPY packages/api/ packages/api/

# Legacy scripts (Slack invitation worker, screenshot capture, etc.)
# still ship via the scripts/ tree. Keep them on PATH so any worker
# handlers that shell out continue to work.
COPY scripts/ ./scripts/

# Symlink node_modules so ESM imports from mounted module scripts at
# /premium-gatewaze-modules can resolve packages like node-ical. Node
# walks up looking for node_modules; without this the walk hits / with
# no match (carried over verbatim from the prior worker dev image).
RUN ln -sfn /app/node_modules /node_modules

# Run the TS worker via tsx watch. Mirrors api's `pnpm dev` script but
# points at the worker entry. The --ignore globs prevent tsx from
# triple-restarting every time a module file under the bind-mounts
# changes (modules are hot-reloaded by the module loader, not tsx).
CMD ["pnpm", "exec", "tsx", "watch", \
     "--ignore", "/gatewaze-modules/**", \
     "--ignore", "/premium-gatewaze-modules/**", \
     "--ignore", "/lf-gatewaze-modules/**", \
     "--ignore", "/app/.gatewaze-modules/**", \
     "--ignore", "/app/supabase/**", \
     "--ignore", "/app/data/**", \
     "packages/api/src/workers/job-worker.ts"]
