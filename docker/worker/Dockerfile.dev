# Worker Development Dockerfile
# Includes nodemon for hot reloading

FROM node:20-slim

# Install dependencies for Puppeteer
RUN apt-get update && apt-get install -y \
    chromium \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# Set Puppeteer to use system Chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

WORKDIR /app

# Copy package files first for better caching
COPY scripts/package.json scripts/package-lock.json ./

# Install dependencies
RUN npm ci

# Copy application code (will be overridden by volume mounts)
COPY scripts/ ./scripts/

# Symlink node_modules so ESM imports from mounted module scripts at
# /premium-gatewaze-modules can resolve packages like node-ical. Node walks
# up from the importer's directory looking for node_modules; without this,
# the walk terminates at / with no match.
RUN ln -sfn /app/node_modules /node_modules

# Use node --watch for hot reloading
CMD ["node", "--watch", "scripts/workers/job-worker.js"]
