###############################################################################
# Gatewaze Docker Environment Configuration
#
# Quick start:
#   cp docker/.env.example docker/.env
#   make up
#
# Multi-brand: Place brand configs in a sibling gatewaze-environments repo,
# then run: make <brand> up
# See: https://github.com/gatewaze/gatewaze-environments
###############################################################################

# =============================================================================
# INSTANCE CONFIGURATION
# =============================================================================

# Docker Compose project name — isolates containers, volumes, and networks
# per brand. Each brand should use a unique value.
COMPOSE_PROJECT_NAME=gatewaze

# Unique name for this Gatewaze instance
INSTANCE_NAME=gatewaze

# =============================================================================
# SUPABASE — JWT & KEYS
# =============================================================================

# JWT secret used to sign/verify tokens (min 32 characters)
# IMPORTANT: For production, generate a new secret: openssl rand -base64 32
# The value below matches the demo ANON_KEY and SERVICE_ROLE_KEY so everything
# works out of the box for local development.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# JWT token expiration in seconds (default: 3600 = 1 hour)
JWT_EXP=3600

# Supabase anonymous (public) key — used by browsers
# These demo keys work with the JWT_SECRET above. For production, generate
# new keys at: https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Supabase service role key — has full access, keep secret
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# =============================================================================
# SUPABASE — DATABASE
# =============================================================================

# PostgreSQL credentials (self-hosted Supabase only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=gatewaze-local-dev
POSTGRES_DB=postgres
POSTGRES_PORT=54322

# Direct database connection URL (required for cloud mode)
# Self-hosted: auto-constructed from above values
# Cloud: postgres://postgres.[ref]:[password]@[host]:5432/postgres
DATABASE_URL=

# =============================================================================
# SUPABASE — URLS
# =============================================================================

# Supabase mode: "local" (self-hosted, default) or "cloud" (Supabase Cloud)
# When set to "cloud", local Supabase containers are NOT started.
SUPABASE_MODE=local

# Allow `make reset` to wipe the cloud Supabase project (database, auth, storage, edge functions).
# Set to "true" ONLY on development/staging environments. Never enable on production.
# ALLOW_CLOUD_RESET=true

# External URL where the Supabase API is reachable (used by browsers)
# Self-hosted: http://gatewaze-supabase.localhost  (via Traefik)
# Cloud: https://[your-project-ref].supabase.co
SUPABASE_URL=http://gatewaze-supabase.localhost

# Internal URL for server-side Supabase calls from Docker containers.
# Self-hosted: leave unset (defaults to http://supabase-kong:8000 via Docker network)
# Cloud: set to the same value as SUPABASE_URL above
# SUPABASE_INTERNAL_URL=https://[your-project-ref].supabase.co

# External URL for Supabase API gateway (self-hosted only)
API_EXTERNAL_URL=http://gatewaze-supabase.localhost

# Site URL for auth redirects (your admin app URL)
SITE_URL=http://gatewaze-admin.localhost

# Allowed redirect URLs for auth (comma-separated)
# Must include the portal URL so magic link redirects work correctly
ADDITIONAL_REDIRECT_URLS=http://gatewaze-app.localhost

# =============================================================================
# TRAEFIK — HOSTNAMES
# =============================================================================

# Hostnames used by Traefik for routing.
# .localhost domains resolve to 127.0.0.1 automatically (RFC 6761).
ADMIN_HOST=gatewaze-admin.localhost
PORTAL_HOST=gatewaze-app.localhost
API_HOST=gatewaze-api.localhost
SUPABASE_HOST=gatewaze-supabase.localhost
STUDIO_HOST=gatewaze-studio.localhost

# Public-facing API URL (used by admin app to call the API)
API_URL=http://gatewaze-api.localhost

# Public-facing portal URL (used for links in emails, speaker tracking, etc.)
# NEXT_PUBLIC_APP_URL=http://gatewaze-app.localhost

# Direct port access (services are available on these ports alongside Traefik)
ADMIN_PORT=5274
PORTAL_PORT=3100
API_PORT=3002
KONG_PORT=54321
STUDIO_PORT=54323

# =============================================================================
# APPLICATION — FRONTEND KEYS
# =============================================================================
# These are passed to the frontend apps at build time. In the default Docker
# Compose setup they are derived automatically from SUPABASE_URL, ANON_KEY,
# and API_URL above — you only need to set them explicitly if your external
# URLs differ from the internal ones (e.g., custom domains).

# Admin app (Vite)
# VITE_SUPABASE_URL=http://gatewaze-supabase.localhost
# VITE_SUPABASE_ANON_KEY=          (defaults to ANON_KEY)
# VITE_API_URL=http://gatewaze-api.localhost
# VITE_APP_URL=http://gatewaze-app.localhost

# Portal (Next.js)
# NEXT_PUBLIC_SUPABASE_URL=http://gatewaze-supabase.localhost
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   (defaults to ANON_KEY)
# NEXT_PUBLIC_API_URL=http://gatewaze-api.localhost

# =============================================================================
# APPLICATION — RUNTIME
# =============================================================================

# Runtime environment (development or production)
NODE_ENV=development

# =============================================================================
# BRANDING & IDENTITY
# =============================================================================

# Brand identifier — used when running multiple brands from the same codebase.
# Leave blank for single-instance deployments.
# BRAND_ID=
# VITE_BRAND_ID=
# VITE_BRAND_NAME=

# =============================================================================
# SUPABASE — AUTH
# =============================================================================

# Disable public signup (true/false)
DISABLE_SIGNUP=false

# Enable email-based signup
ENABLE_EMAIL_SIGNUP=true

# Auto-confirm email addresses (skip verification)
ENABLE_EMAIL_AUTOCONFIRM=false

# =============================================================================
# SUPABASE — REALTIME
# =============================================================================

# Secret key base for Realtime (Erlang/Phoenix sessions)
# Generate with: openssl rand -base64 64
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# =============================================================================
# SUPABASE — EDGE FUNCTIONS
# =============================================================================

# Verify JWT in edge functions (true/false)
# Set to true in production. False for local dev allows unauthenticated
# calls to edge functions (needed for first-time setup).
VERIFY_JWT=false

# =============================================================================
# SUPABASE — STUDIO
# =============================================================================

STUDIO_DEFAULT_ORGANIZATION=Gatewaze
STUDIO_DEFAULT_PROJECT=Gatewaze

# =============================================================================
# REDIS
# =============================================================================

# Redis password (used by BullMQ job queue)
REDIS_PASSWORD=gatewaze

# External Redis URL (for cloud deployments, overrides above)
# REDIS_URL=redis://:password@your-redis-host:6379

# =============================================================================
# EMAIL DELIVERY
# =============================================================================
# Email is configured entirely via environment variables (no UI settings page).
# Set EMAIL_PROVIDER to "sendgrid" or "smtp" to enable email sending.
# Set EMAIL_PROVIDER=none to disable email (default for local dev).

# Provider: "sendgrid", "smtp", or "none" (disabled)
EMAIL_PROVIDER=none

# From address and display name
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=Gatewaze

# --- SendGrid (when EMAIL_PROVIDER=sendgrid) ---
SENDGRID_API_KEY=

# --- SMTP (when EMAIL_PROVIDER=smtp) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =============================================================================
# FILE STORAGE
# =============================================================================

# Storage backend: "file" (local, default) or "s3" (S3-compatible)
STORAGE_BACKEND=file

# S3 configuration (only when STORAGE_BACKEND=s3)
# Works with AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces, etc.
# S3_BUCKET=my-gatewaze-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=false  # Set to true for MinIO and other S3-compatible stores

# =============================================================================
# BRANDING
# =============================================================================

# Set to true to hide Gatewaze logos and powered-by images (white-label)
DISABLE_BRANDING=false

# =============================================================================
# POSTGREST
# =============================================================================

# Schemas exposed by PostgREST
PGRST_DB_SCHEMAS=public,storage,graphql_public

# =============================================================================
# GW_* OVERRIDES (for local development)
# =============================================================================
# These override database-stored settings (app_settings table). Useful when
# pulling production DB dumps to local.
#
# GW_APP_NAME=My Local Brand          # Override the app name shown in the UI

# =============================================================================
# CI/CD MODE
# =============================================================================
# When true, onboarding returns magic links directly instead of sending emails,
# allowing automated setup without an email inbox.
# CI_MODE=true

# =============================================================================
# PUBLIC API / MCP
# =============================================================================

# Pepper for API key HMAC hashing (base64-encoded, 32+ bytes).
# The default below matches the dev API key seeded by the migration.
# MUST be replaced in production.
API_KEY_PEPPER=Z2F0ZXdhemUtZGV2LXBlcHBlci0wMDAwMDAwMDAwMDA=

# Pre-seeded dev API key — works out of the box with the default pepper above.
# Used by dev.sh to generate .mcp.json for Claude Code.
GATEWAZE_MCP_API_KEY=gw_live_dev00000000000000000000000000000001

# =============================================================================
# PRODUCTION-ONLY (do NOT commit values; live in /root/gatewaze/docker/.env on the VPS)
# =============================================================================
#
# These are read by docker-compose.prod.yml. None of them have working
# defaults — every line below MUST be set on the VPS or the prod stack
# will fail to come up. See .drone.yml for the CD pipeline that consumes
# IMAGE_TAG.
#
# Image version pinned by CI on each successful main build:
# IMAGE_TAG=<sha-injected-by-CI>
#
# Module sources — entrypoints clone this on container start. We're
# currently tracking the feature branch (newsletter realtime work);
# switch to #branch=main once it's merged.
# MODULE_SOURCES=https://github.com/gatewaze/premium-gatewaze-modules.git#branch=feature/001890-does-gatewaze-start-up
# GITHUB_TOKEN=<github_pat_with_read_access_to_premium_modules>
#
# External URLs (must match the Caddy stanzas + DNS A records).
# SUPABASE_URL=https://supabase.gatewaze.helix.ml
# API_EXTERNAL_URL=https://supabase.gatewaze.helix.ml
# API_URL=https://api.gatewaze.helix.ml
# SITE_URL=https://gatewaze.helix.ml
# ADMIN_HOST=gatewaze.helix.ml
# PORTAL_HOST=my.helix.ml
#
# Email — Postmark via SMTP. Hetzner blocks outbound 25 by default;
# use 587 (STARTTLS) unless you've requested an exception.
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=<postmark_server_token>
# SMTP_PASS=<postmark_server_token>   # Postmark uses the same token for both
# EMAIL_FROM=newsletters@helix.ml
# EMAIL_FROM_NAME=Helix
#
# Helix research backend (used by the newsletters module's edge functions):
# HELIX_URL=https://meta.helix.ml
# HELIX_API_KEY=<helix_api_key>
# HELIX_PROJECT_ID=<helix_project_id_for_research_tasks>
