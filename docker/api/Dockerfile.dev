FROM node:20-slim

# git + ca-certificates: entrypoint clones module repos.
# curl + bzip2 + libgomp1 / libxcb1 + python3 + pipx: install + runtime
# deps for the Goose CLI binary (added below). The AI module's recipe
# handler (registered in this dev API container via the module-host
# bridge) spawns `goose run` for ai:run-recipe jobs — without these
# the binary won't load.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      ca-certificates \
      curl \
      bzip2 \
      libgomp1 \
      libxcb1 \
      libdbus-1-3 \
      python3 \
      python3-pip \
      pipx \
    && rm -rf /var/lib/apt/lists/*
# Pin pnpm to 10.31.0. `pnpm@latest` (currently 11.1.3) requires
# Node v22.13+, and this image is on node:20-slim — corepack succeeds
# at fetch but the resulting pnpm crashes with ERR_UNKNOWN_BUILTIN_MODULE
# (node:sqlite) on the first install. Same pin already lives in
# docker/worker/Dockerfile.dev for the same reason.
RUN corepack enable && corepack prepare pnpm@10.31.0 --activate

# Install uv + Goose CLI. Same pin as docker/api/Dockerfile (prod) +
# docker/worker/Dockerfile{,.dev}. Renovate (.github/renovate.json5)
# bumps all four together so dev and prod stay in lockstep.
ARG GOOSE_VERSION=v1.34.1
RUN PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install uv
RUN set -eux; \
    arch="$(uname -m)"; \
    case "$arch" in \
      x86_64|amd64) goose_target=x86_64-unknown-linux-gnu ;; \
      aarch64|arm64) goose_target=aarch64-unknown-linux-gnu ;; \
      *) echo "unsupported uname -m=$arch"; exit 1 ;; \
    esac; \
    cd /tmp; \
    curl -fSL --retry 3 \
      "https://github.com/block/goose/releases/download/${GOOSE_VERSION}/goose-${goose_target}.tar.bz2" \
      -o goose.tar.bz2; \
    tar -xjf goose.tar.bz2; \
    mv goose /usr/local/bin/goose; \
    chmod +x /usr/local/bin/goose; \
    rm -f goose.tar.bz2; \
    /usr/local/bin/goose --version

WORKDIR /app

# Copy workspace root files (lockfile excluded – external workspace packages
# from ../gatewaze-modules are not available at build time)
COPY package.json ./
COPY tsconfig.json ./

# Use a workspace config that only includes local packages
RUN printf 'packages:\n  - "packages/*"\n' > pnpm-workspace.yaml

# Copy package manifests for dependency resolution
COPY packages/api/package.json packages/api/
COPY packages/shared/package.json packages/shared/

# Install dependencies (cache pnpm store between builds)
RUN --mount=type=cache,id=pnpm-api-dev,target=/root/.local/share/pnpm/store \
    pnpm install --no-frozen-lockfile

# Copy root config file (referenced by API at runtime via tsx)
COPY gatewaze.config.ts ./
# tsx doesn't resolve .js→.ts for non-project files; create a .js re-export shim
# Root package.json has no "type":"module", so .js files are CJS.
# The API (ESM) imports gatewaze.config.js — CJS→ESM interop wraps default.
# Fix: unwrap the double-default at the CJS layer.
RUN printf 'const m = require("./gatewaze.config.ts");\nconst c = m.default || m;\nObject.defineProperty(c, "__esModule", { value: true });\nmodule.exports = c;\nmodule.exports.default = c;\n' > gatewaze.config.js

# Copy shared source. The api imports `@gatewaze/shared/modules` whose
# package.json `exports` map points at ./dist/*. The repo .dockerignore
# excludes **/dist, so we build it in-image after the COPY. Without this,
# Node ESM can't resolve named exports — older containers worked only
# because they carried a stale dist from a layer predating .dockerignore,
# which surfaced the day a forced rebuild dropped that legacy artifact.
COPY packages/shared/ packages/shared/
RUN pnpm --filter @gatewaze/shared build

# Copy api source (will be overridden by volume mount)
COPY packages/api/ packages/api/

EXPOSE 3002

CMD ["pnpm", "--filter", "api", "dev"]
