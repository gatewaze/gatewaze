FROM node:20-slim

# Pin pnpm to 10.31.0. `pnpm@latest` (now 11.x) requires Node v22.13+,
# and this image is on node:20-slim — corepack succeeds at fetch but the
# resulting pnpm crashes with ERR_UNKNOWN_BUILTIN_MODULE (node:sqlite) on
# the first install. Same pin lives in docker/api and docker/worker.
RUN corepack enable && corepack prepare pnpm@10.31.0 --activate

WORKDIR /app

# Copy workspace root files (lockfile excluded – external workspace packages
# from ../gatewaze-modules are not available at build time)
COPY package.json ./
COPY tsconfig.json ./

# Use a workspace config that only includes local packages
RUN printf 'packages:\n  - "packages/*"\n' > pnpm-workspace.yaml

# Copy package manifests for dependency resolution
COPY packages/portal/package.json packages/portal/
COPY packages/shared/package.json packages/shared/
COPY packages/tracking/package.json packages/tracking/

# Install dependencies (cache pnpm store between builds)
RUN --mount=type=cache,id=pnpm-portal-dev,target=/root/.local/share/pnpm/store \
    pnpm install --no-frozen-lockfile

# Copy shared source (referenced directly, no build step)
COPY packages/shared/ packages/shared/
COPY packages/tracking/ packages/tracking/

# Copy portal source (will be overridden by volume mount)
COPY packages/portal/ packages/portal/

EXPOSE 3100

CMD ["pnpm", "--filter", "portal", "dev", "-H", "0.0.0.0"]
