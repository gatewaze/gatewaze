    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-three/fiber": "^9.5.0",
    "@shadergradient/react": "^2.4.20",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/leaflet": "^1.9.21",
    "ai": "^6.0.141",
    "dompurify": "^3.3.1",
