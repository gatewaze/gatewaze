  "type": "module",
  "scripts": {
    "generate-modules": "tsx scripts/generate-module-registry.ts",
    "dev": "tsx scripts/generate-module-registry.ts && next dev -p 3100 -H 0.0.0.0",
    "build": "tsx scripts/generate-module-registry.ts && next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .open-next",
    "test": "vitest run",
    "opennext:build": "OPENNEXT_BUILD=1 tsx scripts/generate-module-registry.ts && OPENNEXT_BUILD=1 opennextjs-cloudflare build",
    "opennext:preview": "opennextjs-cloudflare preview",
    "opennext:deploy": "opennextjs-cloudflare deploy"
  },
