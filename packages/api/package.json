{
  "name": "@gatewaze/api",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '/gatewaze-modules/**' --ignore '/premium-gatewaze-modules/**' --ignore '/lf-gatewaze-modules/**' --ignore '/app/.gatewaze-modules/**' --ignore '/app/supabase/**' --ignore '/app/data/**' src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/job-worker.js",
    "start:scheduler": "node dist/scheduler/start-scheduler.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "adm-zip": "^0.5.16",
    "bullmq": "^5.25.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}
