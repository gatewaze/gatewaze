{
  "name": "@gatewaze/api",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '/gatewaze-modules/**' --ignore '/premium-gatewaze-modules/**' --ignore '/lf-gatewaze-modules/**' --ignore '/app/.gatewaze-modules/**' --ignore '/app/supabase/**' --ignore '/app/data/**' src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/job-worker.js",
    "start:scheduler": "node dist/scheduler/start-scheduler.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@gatewaze/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "@sentry/node": "^10.51.0",
    "helmet": "^8.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "adm-zip": "^0.5.16",
    "bullmq": "^5.25.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "ts-morph": "^25.0.1",
    "ts-json-schema-generator": "^2.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "tsx": "^4.19.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.33.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.39.1"
  }
}
